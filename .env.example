# ── Supabase (public — safe to expose in browser bundles) ─────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# ── Supabase (server-only — NEVER expose to client) ───────────────────────
SUPABASE_SERVICE_ROLE_KEY=

# ── Anthropic AI (server-only — NEVER expose to client, NEVER prefix NEXT_PUBLIC_) ──
# Used only in src/lib/ai/anthropic.ts — not read anywhere else in the codebase.
# Add to Railway environment variables for production.
ANTHROPIC_API_KEY=
# Optional: override the default model (defaults to claude-sonnet-4-5 if not set)
ANTHROPIC_MODEL=

# ── App ───────────────────────────────────────────────────────────────────
# The public URL where this app is deployed.
# Used to build absolute redirect URLs for Supabase Auth callbacks.
# Example: https://bloom-platform.up.railway.app
NEXT_PUBLIC_APP_URL=
